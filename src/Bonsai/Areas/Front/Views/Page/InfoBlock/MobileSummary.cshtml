@using Bonsai.Areas.Front.ViewModels.Page
@using Bonsai.Areas.Front.ViewModels.Page.InfoBlock
@using Bonsai.Code.DomainModel.Facts.Models
@using Bonsai.Code.Utils.Helpers
@using Bonsai.Localization
@model InfoBlockVM
@{
    var pageVm = (PageTitleVM) ViewBag.PageModel.Body;

    var allFacts = Model.Facts.SelectMany(x => x.Facts).ToList();

    var birthDate  = allFacts.OfType<BirthDateFactModel>().FirstOrDefault();
    var birthPlace = Model.Facts.FirstOrDefault(g => g.Definition.Id == "Birth")
                              ?.Facts.OfType<StringFactModel>()
                               .FirstOrDefault(f => f.Definition.Id == "Place");

    var deathDate  = allFacts.OfType<DeathDateFactModel>().FirstOrDefault();
    var deathPlace = Model.Facts.FirstOrDefault(g => g.Definition.Id == "Death")
                              ?.Facts.OfType<StringFactModel>()
                               .FirstOrDefault(f => f.Definition.Id == "Place");

    // Age shown next to birth only if alive; age at death shown next to death date
    var birthAge = deathDate == null ? birthDate?.Value.GetAge() : null;
    var deathAge = birthDate != null && deathDate?.Value.HasValue == true
                   ? birthDate.Value.GetAge(deathDate.Value.Value)
                   : null;
}

<div class="mobile-summary">
    @if (Model.Photo != null)
    {
        <div class="mobile-summary-photo">
            <img src="@Url.MediaUrl(Model.Photo)" alt="@pageVm.Title" />
        </div>
    }
    <table class="mobile-summary-facts">
        @if (birthDate != null)
        {
            <tr>
                <th>@Texts.Facts_Group_Birth</th>
                <td>
                    @birthDate.Value.ReadableDate
                    @if (!string.IsNullOrEmpty(birthAge))
                    {
                        <span class="mobile-summary-age">(@birthAge)</span>
                    }
                </td>
            </tr>
            @if (!string.IsNullOrEmpty(birthPlace?.Value))
            {
                <tr>
                    <td></td>
                    <td class="mobile-summary-place">@birthPlace.Value</td>
                </tr>
            }
        }
        @if (deathDate != null)
        {
            <tr>
                <th>@Texts.Facts_Group_Death</th>
                <td>
                    @if (deathDate.Value == null)
                    {
                        @Texts.Front_Facts_DeathDate_Unknown
                    }
                    else
                    {
                        @deathDate.Value.Value.ReadableDate
                        @if (!string.IsNullOrEmpty(deathAge))
                        {
                            <span class="mobile-summary-age">(@deathAge)</span>
                        }
                    }
                </td>
            </tr>
            @if (!string.IsNullOrEmpty(deathPlace?.Value))
            {
                <tr>
                    <td></td>
                    <td class="mobile-summary-place">@deathPlace.Value</td>
                </tr>
            }
        }
    </table>
</div>
